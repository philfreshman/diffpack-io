---
import BaseHead from "../components/BaseHead.astro";
import ThemeToggle from "../components/Header/ThemeToggle.tsx";
import GithubIcon from "../components/Icons/GithubIcon.tsx";
import SpaceBackground from "../layouts/SpaceBackground.astro";

const title = "diffpack";
const description =
	"Compare package versions across ecosystems. Source-aware dependency review tool for npm, crates.io, PyPI and RubyGems.";

const tiles = [
	{
		title: "npm",
		subtitle: "JavaScript & TypeScript packages",
		href: "/npm",
		colors: {
			glow: "239, 68, 68", // red-500
		},
	},
	{
		title: "crates.io",
		subtitle: "Rust ecosystem packages",
		href: "/crates",
		colors: {
			glow: "251, 146, 60", // orange-400
		},
	},
	{
		title: "PyPI",
		subtitle: "Python packages",
		href: "/pypi",
		colors: {
			glow: "59, 130, 246", // blue-500
		},
	},
	{
		title: "RubyGems",
		subtitle: "Ruby ecosystem packages",
		href: "/rubygems",
		colors: {
			glow: "220, 38, 38", // red-600
		},
	},
];
---

<!doctype html>
<html lang="en" data-theme>
	<BaseHead title={title} description={description} />

	<body
		class="min-h-screen text-neutral-900 transition-colors duration-300 dark:text-neutral-100"
	>
		<ThemeToggle client:load />
		<SpaceBackground showGradient={true} />

		<main
			class="relative flex min-h-screen flex-col items-center justify-center px-6"
		>
			<header class="mb-16 text-center">
				<h1
					class="text-4xl font-miriam-libre font-bold tracking-tight sm:text-5xl"
				>
					diffpack
				</h1>
				<div class="mt-4 max-w-md text-neutral-600 dark:text-neutral-400">
					<p>Compare package versions across ecosystems.</p>
					<p>Clean. Fast. Source-aware.</p>
				</div>
			</header>

			<div class="grid w-full max-w-4xl grid-cols-1 gap-8 sm:grid-cols-2">
				{tiles.map((tile) => (
					<Fragment key={tile.title}>
						<a
							href={tile.href}
							data-astro-prefetch
							class="group relative block rounded-2xl transition-transform duration-300 hover:scale-[1.02]"
							style={{
								border: `2px solid rgba(${tile.colors.glow}, 0.3)`,
								boxShadow: `0 0 0 rgba(${tile.colors.glow}, 0)`,
							}}
							onmouseover={`this.style.boxShadow='0 0 20px rgba(${tile.colors.glow}, 0.4), 0 0 40px rgba(${tile.colors.glow}, 0.3)'`}
							onmouseout={`this.style.boxShadow='0 0 0 rgba(${tile.colors.glow}, 0)'`}
						>
							<div class="relative h-full rounded-2xl p-8 backdrop-blur-xs dark:bg-neutral-950/40 transition-none">
								<h2 class="text-2xl font-semibold">
									{tile.title}
								</h2>
								<p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">
									{tile.subtitle}
								</p>
								<div class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-neutral-700 dark:text-neutral-200">
									<span>Explore</span>
									<svg
										class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
										aria-hidden="true"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M9 5l7 7-7 7"
										/>
									</svg>
									<span class="sr-only">Explore {tile.title}</span>
								</div>
							</div>
						</a>
					</Fragment>
				))}
			</div>
			<footer class="relative mt-16">
				<p
					class="flex items-center gap-1.5 text-xs text-neutral-400 dark:text-neutral-500"
				>
					More registries coming soon.
					<a
						href="https://github.com/philfreshman/diffpack"
						target="_blank"
						rel="noopener noreferrer"
						class="hover:text-neutral-600 dark:hover:text-neutral-300"
					>
						<GithubIcon />
						<span class="sr-only">GitHub Profile</span>
					</a>
				</p>
			</footer>
		</main>
	</body>
</html>
